# ============================================================
# BusjeDirect — Environment variabelen
# Kopieer dit bestand naar .env.local en vul de waarden in.
# Commit .env.local NOOIT naar git.
# ============================================================

# Mapbox — vereist voor adresautocomplete en routeberekening
# Token ophalen via https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.jouw_token_hier

# Airtable — vereist voor het opslaan van aanvragen
# PAT aanmaken via https://airtable.com/create/tokens
# Scopes nodig: data.records:write
AIRTABLE_PAT=jouw_airtable_pat_hier
AIRTABLE_BASE_ID=jouw_base_id_hier
AIRTABLE_TABLE_NAME=Aanvragen

# Resend — vereist voor het versturen van e-mails
# API key aanmaken via https://resend.com/api-keys
RESEND_API_KEY=jouw_resend_api_key_hier
# Afzenderadres — moet geverifieerd zijn in Resend
RESEND_FROM_EMAIL=BusjeDirect <info@busjedirect.nl>
# Intern notificatieadres — ontvangt elke nieuwe aanvraag
REQUEST_NOTIFICATION_EMAIL=info@busjedirect.nl
